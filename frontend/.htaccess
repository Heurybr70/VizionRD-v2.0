# Redirige todas las rutas a index.html (excepto archivos y carpetas reales)
RewriteEngine On
RewriteBase /

# Si el archivo o directorio existe, servirlo
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Si no existe, redirigir a index.html
RewriteRule ^ index.html [L]
